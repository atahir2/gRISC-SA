# Copy to `.env.production` on the server. Do not commit real secrets.
#
# Tell Compose which file to mount into postgres/app/adminer/migrate (must match this file):
COMPOSE_ENV_FILE_PATH=.env.production

# --- PostgreSQL (must match postgres service credentials) ---
POSTGRES_DB=grisc_sa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong

# From other containers on the Docker network the hostname is `postgres`, not localhost:
DATABASE_URL=postgresql://postgres:change_me_strong@postgres:5432/grisc_sa

# POSTGRES_HOST_PORT=5432
# APP_HOST_PORT=3000
# ADMINER_HOST_PORT=8080

SAQ_DATABASE_PROVIDER=postgres

NEXTAUTH_SECRET=generate_a_long_random_string
AUTH_SECRET=generate_a_long_random_string

# Public URL users use to open the app (must match reverse proxy / TLS)
NEXTAUTH_URL=https://your-host.example

NEXT_PUBLIC_BASE_PATH=
