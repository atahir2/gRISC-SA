# Supabase (SAQ persistence)
# Copy to .env.local and fill in values from your Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public base URL of this app (no trailing slash). Used for email confirmation redirects.
# With Next.js basePath /grisc-sa, use the FULL URL including that path (not host-only):
#   https://mc-a4.lab.uvalight.net/grisc-sa
# Host-only https://mc-a4.lab.uvalight.net breaks Supabase links (missing /grisc-sa).
# If unset at build time, the client uses window.location.origin + NEXT_PUBLIC_BASE_PATH from next.config.js.
NEXT_PUBLIC_SITE_URL=https://mc-a4.lab.uvalight.net/grisc-sa

# Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: same as NEXT_PUBLIC_SITE_URL (e.g. https://host/grisc-sa)
# - Redirect URLs: add https://host/grisc-sa/saq (email confirmation; PKCE ?code= handled on this page).
#   Optionally also https://host/grisc-sa/auth/callback for OAuth / legacy links.
