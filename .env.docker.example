# Copy to `.env.docker` and adjust secrets. Never commit `.env.docker`.
# Compose: docker compose --env-file .env.docker up --build
#
# Optional: which env file is mounted into containers (default `.env.docker`).
# For a production-style file instead, use `.env.production.example` and set:
#   COMPOSE_ENV_FILE_PATH=.env.production

# --- PostgreSQL (must match postgres service credentials) ---
POSTGRES_DB=grisc_sa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin123

# URL seen from OTHER containers on the Compose network — host name `postgres`:
DATABASE_URL=postgresql://postgres:admin123@postgres:5432/grisc_sa

# Optional host port mapping (postgres service → your machine). Default 5432.
# POSTGRES_HOST_PORT=5432

# --- App ---
SAQ_DATABASE_PROVIDER=postgres

# NextAuth — set a long random string in production (same value can be echoed as AUTH_SECRET)
NEXTAUTH_SECRET=RYv1JI5vDw5U5dSKwx+cYDY87HBh9q7JJ53MpjBYHT+q8bSAblQZ3I/qv6gWs2EG
AUTH_SECRET=RYv1JI5vDw5U5dSKwx+cYDY87HBh9q7JJ53MpjBYHT+q8bSAblQZ3I/qv6gWs2EG

# URLs users use in the browser to reach the app (OAuth callbacks / session cookies)
NEXTAUTH_URL=http://localhost:3000

# Served at site root inside Docker (--build-arg NEXT_PUBLIC_BASE_PATH defaults to empty)
NEXT_PUBLIC_BASE_PATH=

# APP_HOST_PORT=3000
# ADMINER_HOST_PORT=8080
